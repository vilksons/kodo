#!/bin/bash

clear && cd "$(dirname "$(realpath "$0")")" || exit 1

mkdir -p "$HOME/kodo"
touch "$HOME/kodo/.kodo.txt"

declare shell_DIR
declare shell_NAME

shell_DIR="$(dirname "$(realpath "$0")")"
shell_NAME="$(basename "$0")"

export OS_NOTICES=0
export OS_NAME="nul"
export SERVERS_INSTATUS=0
export PAWNCC_NAME="nul"
export SAMP_SERVER=""
export zapman_AUTOINSTALL=0
export zapman_AUTOINSTALL_ENCRYPT=""
export zapman_AUTOINSTALL_DECRYPT=""
export vireon_TOKEN_ENCRYPT=""
export vireon_TOKEN_DECRYPT=""
export terminal_SAVE_NOTICE=0
export terminal_KODO_NOTICES=0
export terminal_SAVE_KTOML_LOADED=0
export terminal_MODULAR_LOADED=0
export AGEN_INSTALLER=0
export LICENSES="MIT Licenses."
export CACHE_COMPILERS=".cache/compiler.log"
export compiler_INSTATUS="nul"
export compiler_PAWNCC=""
export compiler_MODE=0
export commands_OPAMX=()
export toml_INCLUDE="nul"
export toml_INCLUDE_FIRST="nul"
export toml_EXCLUDE="nul"
export toml_ZAPMAN_INCLUDE="nul"
export toml_ZAPMAN_PLUGINS="nul"
export toml_LOG_SERV="nul"
export toml_SERVER_CONFIG="nul"
export toml_FILE_SERV="nul"
export toml_EXE_SERV="nul"
export toml_RM_CACHE="nul"
export toml_VIREON_AI_MODEL="nul"
export toml_VIREON_REST_API="nul"
export toml_VIREON_MODEL="nul"
export toml_VIREON_BIODATA="nul"
export toml_VIREON_TOKEN="nul"
export toml_AMX_OPT_F="nul"

color_output() {
    local color="$1" label="$2"
    echo -e "${color}${label}\e[0m"
}

print_color() {
    local color_func="$1" label="$2" content="$3"

    if [ -n "$content" ]; then
        echo -e "$(color_output "$color_func" "$label") $content"
    else
        echo -e "$(color_output "$color_func" "$label")"
    fi
}

COLOR_Y="\e[33m"  # Yellow
COLOR_G="\e[32m"  # Green
COLOR_R="\e[91m"  # Red
COLOR_A="\e[97m"  # Gray

collor_yellow() { color_output "$COLOR_Y" "$1"; }
collor_green() { color_output "$COLOR_G" "$1"; }
collor_red() { color_output "$COLOR_R" "$1"; }
collor_gray() { color_output "$COLOR_A" "$1"; }

print_yellow() { print_color "$COLOR_Y" "$1" "$2"; }
print_green() { print_color "$COLOR_G" "$1" "$2"; }
print_red() { print_color "$COLOR_R" "$1" "$2"; }
print_gray() { print_color "$COLOR_A" "$1" "$2"; }

bash_title() {
    echo -ne "\033]0;$1\007"
}

kodo_t_TITLE() {
    local title=$1
    shell_TITLE="$title"
    bash_title "$shell_TITLE"
}

export collor_yellow collor_green collor_red collor_gray print_yellow print_green print_red print_gray kodo_t_TITLE

if [ ! -d ".cache" ]; then
    mkdir ".cache" && chmod +x ".cache"
fi

function SIGNAL_KILL()
{
    kd_table="kill"
    goto_mode_KODO "$kd_table"
}

function IGNORE_ME() {
    "$@" > /dev/null 2>&1
}
export IGNORE_ME

function load_function_with_check()
{
    if ! declare -f "$1" > /dev/null; then
        print_red "error:" "Function '$1' not found"
        return 1
    fi

    "$1" "$2" || {
        if [ "$terminal_MODULAR_LOADED" -eq 1 ]; then
            print_green "warn:" "err.. need to kill after installing \"succes\".."
            print_green " killing.."
            sleep 0.999 && SIGNAL_KILL "" && typeof ""
        fi
    }
}
export load_function_with_check

function __kodo_toml_create__() {
    openmp=$(find . -maxdepth 1 -type f \( -name "omp-server" -o -name "omp-server.exe" \) | head -n 1)
    samp=$(find . -maxdepth 1 -type f \( -name "samp03svr" -o -name "samp-server.exe" \) | head -n 1)

    if [[ -n "$samp" ]] && [[ -n "$openmp" ]]; then
        SAMP_SERVER="samp"
    elif [[ -n "$u_samp" ]]; then
        SAMP_SERVER="samp"
    elif [[ -n "$openmp" ]]; then
        SAMP_SERVER="omp"
    else
        SAMP_SERVER="samp"
    fi

    if [ ! -f "kodo.toml" ]; then
        local kodo_toml_log="" kodo_toml_config="" kodo_toml_include="" kodo_toml_exec=""

        if [[ "$SAMP_SERVER" == "samp" ]]; then
            [[ "$OS_NAME" == "windows" ]] && kodo_toml_exec="samp-server.exe"
            [[ "$OS_NAME" == "linux" ]] && kodo_toml_exec="samp03svr"
            kodo_toml_log="server_log.txt"; kodo_toml_config="server.cfg"; kodo_toml_include="pawno/include";
        elif [[ "$SAMP_SERVER" == "omp" ]]; then
            [[ "$OS_NAME" == "windows" ]] && kodo_toml_exec="omp-server.exe"
            [[ "$OS_NAME" == "linux" ]] && kodo_toml_exec="omp-server"
            kodo_toml_log="log.txt"; kodo_toml_config="config.json"; kodo_toml_include="qawno/include"; kodo_toml_exec="omp-server.exe"
        fi

        cat > kodo.toml <<EOF
[paths]
include_paths = "$kodo_toml_include"
include_dir = "include"
plugins_dir = "plugins"

[server]
log = "$kodo_toml_log"
config = "$kodo_toml_config"
init = "main.pwn"
executable = "$kodo_toml_exec"
remcache_auto = false

[vireon]
ai_model = "groq"
rest_api = "https://api.groq.com/openai/v1/chat/completions"
token = "your_token"
model = "compound-beta"
profile = "your name is vireon."

[compiler]
exclude_paths = ["includes1/", "includes2/", "includes3/"]
amx_flags = ['-d2', '-;+', '-(+', '-Z+']
EOF
    fi
}

function __kodo_toml_load__() {
    local yq_cmd="yq eval -o=json"

    # paths
    toml_INCLUDE=$($yq_cmd '.paths.include_paths' kodo.toml | jq -r '.')
    
    if [[ -z "$toml_INCLUDE" ]]; then
        print_red "error:" "failed to load \"include_paths\"" && typeof ""
    else
        toml_INCLUDE_FIRST=$(echo "$toml_INCLUDE" | head -n 1 | cut -d'/' -f1)
    fi

    toml_ZAPMAN_INCLUDE=$($yq_cmd '.paths.include_dir' kodo.toml | jq -r '.')
    [[ "$toml_ZAPMAN_INCLUDE" == "null" ]] && print_red "error:" "failed to load \"include_dir\"" && typeof ""

    toml_ZAPMAN_PLUGINS=$($yq_cmd '.paths.plugins_dir' kodo.toml | jq -r '.')
    [[ "$toml_ZAPMAN_PLUGINS" == "null" ]] && print_red "error:" "failed to load \"plugins_dir\"" && typeof ""

    # server
    toml_LOG_SERV=$($yq_cmd '.server.log' kodo.toml | jq -r '.')
    [[ "$toml_LOG_SERV" == "null" ]] && print_red "error:" "failed to load \"log\"" && typeof ""

    toml_SERVER_CONFIG=$($yq_cmd '.server.config' kodo.toml | jq -r '.')
    [[ "$toml_SERVER_CONFIG" == "null" ]] && print_red "error:" "failed to load \"config\"" && typeof ""

    toml_FILE_SERV=$($yq_cmd '.server.init' kodo.toml | jq -r '.')
    [[ "$toml_FILE_SERV" == "null" ]] && print_red "error:" "failed to load \"init\"" && typeof ""

    toml_EXE_SERV=$($yq_cmd '.server.executable' kodo.toml | jq -r '.')
    [[ "$toml_EXE_SERV" == "null" ]] && print_red "error:" "failed to load \"executable\"" && typeof ""

    toml_RM_CACHE=$($yq_cmd '.server.remcache_auto' kodo.toml | jq -r '.')
    [[ "$toml_RM_CACHE" == "null" ]] && print_red "error:" "failed to load \"remcache_auto\"" && typeof ""

    # vireon
    toml_VIREON_AI_MODEL=$($yq_cmd '.vireon.ai_model' kodo.toml | jq -r '.')
    [[ "$toml_VIREON_AI_MODEL" == "null" ]] && print_red "error:" "failed to load \"ai_model\"" && typeof ""

    toml_VIREON_REST_API=$($yq_cmd '.vireon.rest_api' kodo.toml | jq -r '.')
    [[ "$toml_VIREON_REST_API" == "null" ]] && print_red "error:" "failed to load \"rest_api\"" && typeof ""

    toml_VIREON_MODEL=$($yq_cmd '.vireon.model' kodo.toml | jq -r '.')
    [[ "$toml_VIREON_MODEL" == "null" ]] && print_red "error:" "failed to load \"model\"" && typeof ""

    toml_VIREON_BIODATA=$($yq_cmd '.vireon.profile' kodo.toml | jq -r '.')
    [[ "$toml_VIREON_BIODATA" == "null" ]] && print_red "error:" "failed to load \"profile\"" && typeof ""

    toml_VIREON_TOKEN=$($yq_cmd '.vireon.token' kodo.toml | jq -r '.')
    [[ "$toml_VIREON_TOKEN" == "null" ]] && print_red "error:" "failed to load \"token\"" && typeof ""

    # compiler
    toml_EXCLUDE=$($yq_cmd '.compiler.exclude_paths // [] | .[]' kodo.toml | jq -r '.' | xargs -I {} echo -n "-i\"{}\" ")
    [[ -z "$toml_EXCLUDE" ]] && print_red "error:" "failed to load \"exclude_paths\"" && typeof ""

    toml_AMX_OPT_F=$($yq_cmd '.compiler.amx_flags // [] | .[]' kodo.toml | jq -r '.' | xargs)
    [[ -z "$toml_AMX_OPT_F" ]] && print_red "error:" "failed to load \"amx_flags\" && typeof """
}

function struct_kodo_t_main() {
    kodo_t_missing_save_cmds=(python3 unzip tar curl grep awk sed tr jq yq openssl)
    kodo_t_missing_cmds=()
    missing_cmds=()

    for cmd in "${kodo_t_missing_save_cmds[@]}"; do
        if ! command -v "$cmd" &>/dev/null; then
            case "$cmd" in
                awk)
                    kodo_t_missing_cmds+=("gawk")
                    missing_cmds+=("gawk")
                    ;;
                tr)
                    kodo_t_missing_cmds+=("coreutils")
                    missing_cmds+=("coreutils")
                    ;;
                *)
                    kodo_t_missing_cmds+=("$cmd")
                    missing_cmds+=("$cmd")
                    ;;
            esac
        fi
    done

    if [ ${#kodo_t_missing_cmds[@]} -ne 0 ]; then
        print_green "missing packages: ${missing_cmds[*]} not found, installing.."
    fi

    local pkg_manager=""
    for manager in apt pkg dnf pacman zypper yum; do
        if command -v "$manager" &>/dev/null; then
            pkg_manager="$manager"
            break
        fi
    done

    for cmd in "${kodo_t_missing_cmds[@]}"; do
        case "$pkg_manager" in
            apt|pkg|dnf|yum|zypper)
                if command -v sudo &>/dev/null; then
                    sudo "$pkg_manager" install -y "$cmd"
                else
                    "$pkg_manager" install -y "$cmd"
                fi
                ;;
            pacman)
                if command -v sudo &>/dev/null; then
                    sudo pacman -S --noconfirm "$cmd"
                else
                    pacman -S --needed "$cmd"
                fi
                ;;
            *)
                print_red "error:" "Can't find Package Manager. Only apt/pkg/dnf/pacman/zypper/yum supported."
                print_red "Missing packages:" "${kodo_t_missing_cmds[*]}"
                printf "\e]8;;https://github.com/vilksons/kodo/wiki/Required-Packages\e\\ Please see here for more.\e]8;;\e\\\n"
                IGNORE_ME sleep 1.0
                terminal_SAVE_NOTICE=2
                ;;
        esac
    done

    if [[ " ${kodo_t_missing_cmds[*]} " == *" yq "* ]] && ! command -v yq &>/dev/null; then
        arch=$(uname -m)
        yq_url=""
        case "$arch" in
            x86_64) yq_url="yq_linux_amd64" ;;
            i386) yq_url="yq_linux_386" ;;
            arm64) yq_url="yq_linux_arm64" ;;
            armv7l) yq_url="yq_linux_arm" ;;
            *) echo "unknown arch: $arch, can't download yq." ;;
        esac

        if [ -n "$yq_url" ]; then
            if command -v sudo &>/dev/null; then
                sudo curl -L "https://github.com/mikefarah/yq/releases/download/v4.45.1/$yq_url" -o /usr/bin/yq
                wait && sudo chmod +x /usr/bin/yq
            else
                curl -L "https://github.com/mikefarah/yq/releases/download/v4.45.1/$yq_url" -o /usr/bin/yq
                wait && chmod +x /usr/bin/yq
            fi

            sleep 0.999 && SIGNAL_KILL ""
        fi
    fi
    
    if [ "$terminal_SAVE_NOTICE" -eq 0 ]; then
        if [ -f ".sync" ]; then
            shred -u .sync
            if [ -d "$shell_DIR/.kodo" ]; then
                rm -rf ".kodo"
            fi
        fi

        if [ ! -d ".kodo" ]; then
            mkdir -p ".kodo/python" && chmod +x ".kodo"
        fi

        function kodo_t_pack() {
            : ' Install or Load modules '
            if [ -f "$shell_DIR/$1" ] && [ "$terminal_MODULAR_LOADED" -ne 1 ]; then
                chmod +x "$shell_DIR/$1"
                if [ "$1" != ".kodo/python/vipython" ]; then
                    if [[ "$1" == ".kodo/python/wpython" ]]; then
                        source <(python3 .kodo/python/wpython) || sleep 1.0
                    else
                        if [[ "$1" == ".kodo/compat.kd" ]]; then
                            source "$shell_DIR/$1" || sleep 1.0
                            kodo_compat ""
                        else
                            source "$shell_DIR/$1" || sleep 1.0
                        fi
                    fi
                fi

                if [ "$terminal_MODULAR_LOADED" -eq 1 ]; then
                    print_green "warn:" "err.. need to kill after installing \"succes\".."
                    print_green " killing.."
                    sleep 0.999 && SIGNAL_KILL "" && typeof ""
                fi
            else
                bash_title "Waiting resources.."

                if [ "$3" != "silent" ]; then
                    curl -L -o "$shell_DIR/$1" "$2" &>/dev/null
                else
                    curl -L -o "$shell_DIR/$1" "$2" &>/dev/null &
                fi

                if [ "$3" = "end" ]; then
                    terminal_MODULAR_LOADED=1
                    terminal_SAVE_NOTICE=1

                    curl -L -o "$shell_DIR/$1" "$2" &>/dev/null &
                    clear && cd "$(dirname "$(realpath "$0")")" || echo
                
                    print_yellow "install succes!"
                    print_green " killing.."

                    sleep 0.999 && SIGNAL_KILL "" && typeof ""
                fi
            fi
        }

        local modules=()
        modules=(
            ".kodo/python/wpython|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/wpython|"
            ".kodo/python/vipython|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/vipython|"
            ".kodo/compat.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Compat/compat.kd|compat"
            ".kodo/compiler.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Compiler/compiler.kd|silent"
            ".kodo/zapman.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Zapman/zapman.kd|silent"
            ".kodo/samp.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Package/samp.kd|silent"
            ".kodo/pawncc.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Package/pawncc.kd|silent"
            ".kodo/misc.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Misc/misc.kd|silent"
            ".kodo/vireon.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Vireon/vireon.kd|silent"
            ".kodo/server.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Server/server.kd|silent"
            ".kodo/security.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Security/security.kd|end"
        )

        for module in "${modules[@]}"; do
            IFS="|" read -r path url flag <<< "$module"
            kodo_t_pack "$path" "$url" "$flag"
        done

        cd "$shell_DIR" >/dev/null 2>&1 || echo ""

        if [ "$terminal_SAVE_KTOML_LOADED" -eq 0 ]; then
            load_function_with_check __kodo_toml_create__ "" 
            load_function_with_check __kodo_toml_load__ ""
            terminal_SAVE_KTOML_LOADED=1
        fi
    fi

    if [ -f ".kodo/security.kd" ]; then
        load_function_with_check __encryption_create__ ""
        load_function_with_check __encryption_token__ ""
    fi
    
    typeof ""
}
export struct_kodo_t_main

function typeof() {
    if [ "$terminal_MODULAR_LOADED" != 1 ]; then
        kodo_t_TITLE "Kodo Mode | Usage \`help\`"

        if [ "$terminal_KODO_NOTICES" -eq 0 ]; then
            terminal_KODO_NOTICES=1
            echo "Welcome to Kodo!"
            printf " Docs: "
            printf "\e]8;;https://github.com/vilksons/kodo/wiki\e\\https://github.com/vilksons/kodo/wiki\e]8;;\e\\"
            echo
            printf " Help: "
            printf "\e]8;;https://github.com/vilksons/kodo/issues\e\\https://github.com/vilksons/kodo/issues\e]8;;\e\\"
            echo
            printf " Discussion: "
            printf "\e]8;;https://github.com/vilksons/kodo/discussions\e\\https://github.com/vilksons/kodo/discussions\e]8;;\e\\"
            echo
        fi
    fi

    HISTFILE="$HOME/kodo/.kodo.txt"
    touch "$HISTFILE"

    history -r "$HISTFILE"
    read -e -r -p "kodo:~$ " kd_table
    
    if [ -n "$kd_table" ]; then
        echo "$kd_table" >> "$HISTFILE"
    fi

    goto_mode_KODO "$kd_table"
}
export typeof

function goto_mode_KODO() {
    local trigger_kd="kodo"

    case "$kd_table" in
        "compile"*)
            kodo_t_TITLE "Compiler"

            local commands_ARGS="${kd_table#compile }"
            local commands_INPUT=""

            for arg in $commands_ARGS; do
                if [ -z "$commands_INPUT" ]; then
                    commands_INPUT="$arg"
                else
                    commands_OPAMX+=("$arg")
                fi
            done

            load_function_with_check kodo_init_compilers "$commands_INPUT"
            ;;
        "running"*)
            kodo_t_TITLE "Running"
            
            local commands_ARGS="${kd_table#running }"

            SERVERS_INSTATUS=1
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"

                if [[ "$commands_INPUT" == "." ]]; then
                    load_function_with_check workspace_servers ""
                else
                    load_function_with_check workspace_wargs_servers "$commands_INPUT"
                fi
            else
                load_function_with_check workspace_servers ""
            fi
            ;;
        "irunn")
            kodo_t_TITLE "Compile & Running"

            compiler_INSTATUS="false"
            
            load_function_with_check kodo_compilers ""
            ;;
        "debug"*)
            kodo_t_TITLE "Debugging"

            local commands_ARGS="${kd_table#debug }"

            SERVERS_INSTATUS=2
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"

                if [[ "$commands_INPUT" == "." ]]; then
                    load_function_with_check workspace_servers ""
                else
                    load_function_with_check workspace_wargs_servers "$commands_INPUT"
                fi
            else
                print_gray ":: Enter GM Name:"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi
            ;;
        "stop")
            kodo_t_TITLE "Stop"
            IGNORE_ME pkill -15 -f "$toml_EXE_SERV"
            end_kodo_t_main ""
            ;;
        "restart")
            kodo_t_TITLE "Restart"
            IGNORE_ME pkill -15 -f "$toml_EXE_SERV"
            workspace_servers ""
            ;;
        "gamemode")
            kodo_t_TITLE "Downloads | GameMode"

            load_function_with_check struct_choice_samp ""
            ;;
        "pawncc")
            kodo_t_TITLE "Downloads | PawnCC"

            load_function_with_check struct_choice_pawncc ""
            ;;
        "cat"*)
            kodo_t_TITLE "Cat Files"

            local commands_ARGS="${kd_table#cat }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"
                echo
                cat "$commands_INPUT"
            else
                print_gray ":: Enter File Name:"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi
            
            typeof ""
            ;;
        "directory"* | "cd"*)
            kodo_t_TITLE "Directory - $shell_DIR"

            local commands_ARGS="${kd_table#directory }"
            local commands_ARGS="${kd_table#cd }"
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"

                if [ -d "$commands_INPUT" ]; then
                    if [ -f "kodo.toml" ]; then
                        print_yellow "copy the \"kodo.toml\" folder too? [y/n]"
                        read -r -p ">> " NEEDED_RES_MVKD

                        if [ "$NEEDED_RES_MVKD" == "Y" ] || [ "$NEEDED_RES_MVKD" == "y" ]; then
                            cp "kodo.toml" "$commands_INPUT/kodo.toml"
                        fi
                    fi
                    if [ -d ".kodo" ]; then
                        print_yellow "copy the \".kodo\" folder too? [y/n]"
                        read -r -p ">> " NEEDED_RES_MVKD

                        if [ "$NEEDED_RES_MVKD" == "Y" ] || [ "$NEEDED_RES_MVKD" == "y" ]; then
                            cp -r ".kodo" "$commands_INPUT/.kodo"
                        fi
                    fi
                        
                    IGNORE_ME cd "$commands_INPUT"
                    ls -a &&
                        shell_TITLE="directory - $shell_DIR" &&
                            bash_title "$shell_TITLE" || echo && end_kodo_t_main ""
                else
                    print_red "error:" "Can't found directory \"$commands_INPUT\" please verify first!."
                fi
            else
                if [ "$kd_table" == "ls" ]; then
                    ls -a
                else
                    cd "$shell_DIR" || echo
                fi
            fi

            end_kodo_t_main ""
            ;;
        "ls")
            ls -a
            typeof ""
            ;;
        "kill")
            terminal_SAVE_NOTICE=0
            terminal_KODO_NOTICES=0

            IGNORE_ME clear

            cd "$shell_DIR" || echo
            exec bash ./"$shell_NAME"
            ;;
        "refresh")
            terminal_SAVE_NOTICE=0
            terminal_SAVE_KTOML_LOADED=0

            struct_kodo_t_main ""
            ;;
        "sync"*)
            if [[ "$kd_table" == "sync" ]]; then
                kodo_t_TITLE "Sync"
            fi

            local commands_ARGS="${kd_table#sync }"

            local latest="" current=""
            latest=$(
                curl -s "https://api.github.com/repos/vilksons/kodo/commits/kodo" |
                    grep -o '"sha": "[^"]*' | awk -F': "' '{print $2}'
            )
            if [ -f "$shell_DIR/.itskodo" ]; then
                current=$(
                    cat "$shell_DIR/.itskodo" 2>/dev/null
                )
            else
                current="444"
            fi
            
            if [[ "$latest" == "$current" ]]; then
                echo "warning: $shell_NAME is up to date, Nothing to do."
                end_kodo_t_main ""
            else
                print_gray ":: New Commits Found..: Commits (SHA1): "
                echo "$latest"
                echo
                curl -I "https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/workspace?nocache=$(date +%s)"

                print_green " Make sure you have seen the latest commits that have been pushed from 20 minutes ago for stability and re-verify and sync what has been published."
                read -r -n1 -p ":: Do you want to continue Sync Kodo? [y/n] " PERMISSION_NEED_S
                echo
                [[ -z "$PERMISSION_NEED_S" ]] && PERMISSION_NEED_S="Y"

                case "$PERMISSION_NEED_S" in
                    [Yy])
                        if [[ -d "$shell_DIR/.kodo" ]]; then
                            dest="kodo_modules_old"
                            i=1
                            while [[ -e "$dest" ]]; do
                                dest="kodo_modules_old_$i"
                                ((i++))
                            done
                            mv "$shell_DIR/.kodo" "$dest"
                        fi

                        if [ ! -d ".kodo" ]; then
                            mkdir -p ".kodo/python" && chmod +x ".kodo"
                        fi

                        echo "$latest" > "$shell_DIR/.itskodo"

                    __modular__() {
                        kodo_t_TITLE "Sync | Upgrade"
                        echo "Comparing Local and Remote..."

                        __kodo_modular__=(
                            "Security/security.kd"
                            "Compat/compat.kd"
                            "Zapman/zapman.kd"
                            "Package/samp.kd"
                            "Package/pawncc.kd"
                            "Server/server.kd"
                            "Misc/misc.kd"
                            "Vireon/vireon.kd"
                            "Compiler/compiler.kd"
                        )

                        cd "$shell_DIR/.kodo" >/dev/null 2>&1 || echo ""
                        for __file__ in "${__kodo_modular__[@]}"; do
                            fname=$(basename "$__file__")
                            local_path="$shell_DIR/.kodo/$fname"
                            remote_url="https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/$__file__"
                            remote_content=$(curl -s "$remote_url")
                            local_content=$(cat "$local_path" 2>/dev/null || echo "")

                            if [[ "$remote_content" == "$local_content" ]]; then
                                print_gray ":: $fname is up to date, Nothing to do."
                            else
                                print_yellow "Updating: $fname"
                                echo "$remote_content" > "$local_path"
                            fi
                        done

                        cd "$shell_DIR/.kodo/python" >/dev/null 2>&1 || echo ""

                        for pyfile in "wpython" "vipython"; do
                            remote_url="https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/$pyfile"
                            remote_content=$(curl -s "$remote_url")
                            local_path="$shell_DIR/.kodo/python/$pyfile"
                            local_content=$(cat "$local_path" 2>/dev/null || echo "")

                            if [[ "$remote_content" == "$local_content" ]]; then
                                print_gray ":: $pyfile is up to date, Nothing to do."
                            else
                                print_yellow "Updating: $pyfile"
                                echo "$remote_content" > "$local_path"
                            fi
                        done

                        cd "$shell_DIR" >/dev/null 2>&1 || echo ""

                        remote_url="https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/workspace"
                        remote_content=$(curl -s "$remote_url")
                        local_path="$shell_DIR/workspace"
                        local_content=$(cat "$local_path" 2>/dev/null || echo "")

                        if [[ "$remote_content" == "$local_content" ]]; then
                            print_gray ":: workspace is up to date, Nothing to do."
                        else
                            print_yellow "Updating: workspace"
                            echo "$remote_content" > "$local_path"
                        fi
                    }

                        if [ "$kd_table" = "sync" ]; then
                            __modular__ ""
                        elif [ "$commands_ARGS" = "update" ]; then
                            kodo_t_TITLE "Sync | Update"

                            echo "Updating.."

                            cd "$shell_DIR" >/dev/null 2>&1 || echo ""

                            remote_url="https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/workspace"
                            remote_content=$(curl -s "$remote_url")
                            local_path="$shell_DIR/workspace"
                            local_content=$(cat "$local_path" 2>/dev/null || echo "")

                            if [[ "$remote_content" == "$local_content" ]]; then
                                print_gray ":: workspace is up to date, Nothing to do."
                            else
                                print_yellow "Updating: workspace"
                                echo "$remote_content" > "$local_path"
                            fi
                        else
                            __modular__ ""
                        fi

                        chmod +x "$shell_DIR/$shell_NAME"
                        bash "$shell_DIR/$shell_NAME"
                        ;;
                    *)
                        end_kodo_t_main ""
                        ;;
                esac
            fi
            ;;
        "toml")
            if [ -f "$shell_DIR/kodo.toml" ]; then
                mv kodo.toml kodo.toml.old.txt
            fi

            terminal_MODULAR_LOADED=0
            __kodo_toml_create__ ""
            typeof ""
            ;;
        "checksums"*)
            kodo_t_TITLE "Checksums"

            local commands_ARGS="${kd_table#checksums }"

            IGNORE_ME cd "$shell_DIR" || echo ""

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                echo "sha1:" && sha1sum "$shell_NAME" && echo "sha256:" && sha256sum "$shell_NAME" && echo "md5:" && md5sum "$shell_NAME"
            fi

            for algo in $commands_INPUT; do
                if [[ "$algo" == "sha1" ]]; then
                    echo "sha1:" && sha1sum "$shell_NAME"
                elif [[ "$algo" == "sha256" ]]; then
                    echo "sha256:" && sha256sum "$shell_NAME"
                elif [[ "$algo" == "md5" ]]; then
                    echo "md5:" && md5sum "$shell_NAME"
                else
                    echo "Invalid option: $algo (use sha1, sha256, md5)"
                fi
            done

            end_kodo_t_main ""
            ;;
        "exit")
            IGNORE_ME pkill -9 -f "$shell_NAME"
            ;;
        "vireon"*)
            kodo_t_TITLE "Vireon Chat A.I"

            local commands_ARGS="${kd_table#vireon }"

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                print_gray ":: Enter Question:"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi
            
            kodo_vireon "$commands_INPUT"
            ;;
        "nano"*)
            if ! command -v nano &> /dev/null; then
                print_red "crit:" "nano not found!, install first."
                end_kodo_t_main ""
            fi
            
            kodo_t_TITLE "GNU/Nano"
            
            local commands_ARGS="${kd_table#nano }"

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"
            else
                print_gray ":: Enter Names:"
                while true; do
                    read -r -p ">>> " commands_INPUT
                    [[ -n "$commands_INPUT" ]] && break
                done
            fi

            nano "$commands_INPUT"
            end_kodo_t_main ""
            ;;
        "remcac")
            kodo_t_TITLE "Remove Cache"

            if [ "$compiler_INSTATUS" != "nul" ]; then
                print_red "crit:" "can't remove cache!."
            fi

            if [ ! -f "$shell_DIR/.cache/zapman" ] && [ ! -f "$shell_DIR/.cache/compiler.log" ]; then
                echo "no cache found."
            fi

            if [ -f "$shell_DIR/.cache/zapman" ]; then
                print_gray ":: Cache Dir: $shell_DIR/.cache/zapman"
                read -r -p ":: Do you want to remove ALL files from $shell_DIR/.cache/zapman? [y/n] " PERMISSION_NEED_RC
                echo
                [[ -z "$PERMISSION_NEED_RC" ]] && PERMISSION_NEED_RC="Y"

                while true; do
                    case "$PERMISSION_NEED_RC" in
                        [Yy])
                            cd "$shell_DIR" || echo
                            shred -u ".cache/zapman" && print_yellow " successfully"
                            sleep 1
                            break
                            ;;
                        *)
                            echo "Operation cancelled"
                            break
                            ;;
                    esac
                done
            fi

            if [ -f "$shell_DIR/.cache/compiler.log" ]; then
                print_gray ":: Cache Dir: $shell_DIR/.cache/compiler.log"
                read -r -p ":: Do you want to remove ALL files from $shell_DIR/.cache/compiler.log? [y/n] " PERMISSION_NEED_RC
                echo
                [[ -z "$PERMISSION_NEED_RC" ]] && PERMISSION_NEED_RC="Y"

                while true; do
                    case "$PERMISSION_NEED_RC" in
                        [Yy])
                            cd "$shell_DIR" || echo
                            shred -u ".cache/compiler.log" && print_yellow " successfully"
                            sleep 1
                            ;;
                        *)
                            echo "Operation cancelled"
                            ;;
                    esac
                done
            fi
            end_kodo_t_main ""
            ;;
        "fetch")
            fetch_now ""
            ;;
        "zapman")
            load_function_with_check goto_mode_ZAPMAN ""
            ;;
        "clear" | "c" | "C" | "cc")
            terminal_KODO_NOTICES=0
            clear; echo -ne "\033[3J"
            typeof ""
            ;;
        "modular"*)
            kodo_t_TITLE "Modular Checking | Debugging"

            function kodo_t_modular_load() {
                : ' Install or Load modules '
                if [ -f "$shell_DIR/$1" ]; then
                    chmod +x "$shell_DIR/$1"

                    echo "[DEBUGGING]: $1"

                    if [[ "$1" == ".kodo/python/wpython" ]]; then
                        python3 .kodo/python/wpython && print_yellow "Succes"
                    else
                        source "$shell_DIR/$1" && print_yellow "Succes"
                    fi
                fi
            }

            local commands_ARGS="${kd_table#modular }"

            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                commands_INPUT="$commands_ARGS"

                if [ -f "$commands_INPUT" ]; then
                    printf_red "error:" "$commands_INPUT not found!."
                fi

                kodo_t_modular_load "$commands_INPUT" "https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/$commands_INPUT" ""
            else
                kodo_t_modular_load ".kodo/python/wpython" "https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Scripts/wpython" ""

                cd "$shell_DIR/.kodo" >/dev/null 2>&1 || echo ""
                
                local modules=()
                modules=(
                    ".kodo/security.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Security/security.kd|silent"
                    ".kodo/compat.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Compat/compat.kd|compat"
                    ".kodo/compiler.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Compiler/compiler.kd|silent"
                    ".kodo/zapman.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Zapman/zapman.kd|silent"
                    ".kodo/samp.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Package/samp.kd|silent"
                    ".kodo/pawncc.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Package/pawncc.kd|silent"
                    ".kodo/misc.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Misc/misc.kd|silent"
                    ".kodo/vireon.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Vireon/vireon.kd|silent"
                    ".kodo/server.kd|https://raw.githubusercontent.com/vilksons/kodo/refs/heads/kodo/Server/server.kd|end"
                )

                for module in "${modules[@]}"; do
                    IFS="|" read -r path url flag <<< "$module"
                    kodo_t_pack "$path" "$url" "$flag"
                done
            fi

            typeof ""
            ;;
        "help"* | "$trigger_kd -h"* | "$trigger_kd --h"*)
            local commands_ARGS="${kd_table#"$trigger_kd -h "}"
            local commands_ARGS="${commands_ARGS#help }"
            local commands_ARGS="${commands_ARGS#"$trigger_kd --h "}"

            declare -A descriptions=(
                ["compile"]=":: Compile a project - Usage: compile | (+) [<args>] [target]"
                ["running"]=":: Running a project - Usage: running | (+) [<args>] [target]"
                ["irunn"]=":: Compile & Running a project - Usage: irunn"
                ["debug"]=":: Debug a project - Usage: debug | (+) [<args>] [target]"
                ["stop"]=":: stop all running project progress - Usage: stop"
                ["restart"]=":: Restart all Server - Usage: restart"
                ["gamemode"]=":: Download GameModes SA-MP with Selection - Usage: gamemode"
                ["pawncc"]=":: Download PawnCC SA-MP with Selection - Usage: pawncc"
                ["clear"]=":: Clear Screen Terminal - Usage: clear"
                ["checksums"]=":: Checksums of Kodo - Usage: checksums"
                ["cat"]=":: Display a files to Kodo Terminal - Usage: cat"
                ["kill"]=":: Kill a Kodo Terminal - Usage: kill"
                ["exit"]=":: Exit/End Kodo Terminal - Usage: exit"
                ["toml"]=":: Rebuild kodo.toml - Usage: toml"
                ["refresh"]=":: Refresh Terminal, kodo.toml, etc. - Usage: refresh"
                ["directory"]=":: Display or Change Terminal Directory - Usage: directory | cd | ls"
                ["remcac"]=":: Remove cache \".cache\" Kodo - Usage: remcac"
                ["vireon"]=":: Vireon Chat - Usage: vireon"
                ["nano"]=":: GNU/Nano Editor - Usage: nano"
                ["zapman"]=":: Kodo Mode to Zapman Mode - Usage: zapman"
                ["autoinstall"]=":: Zapman Mode | AutoInstall Package -> Usage: autoinstall"
                ["install"]=":: Zapman Mode | Install Package -> Usage: install | (+) [<args>] [url]"
                ["remove"]=":: Zapman Mode | Remove Package -> Usage: remove | (+) [<args>] [target]"
                ["sync"]=":: Sync(hronization) - Usage: sync | (+) [<args>] [update - only workspace]"
                ["modular"]=":: Modular Checking - Usage: modular | (+) [<args>] [target]"
                ["fetch"]=":: Fetch Kodo -> Usage: fetch"
            )
            
            if [[ -n "$commands_ARGS" && "$commands_ARGS" != "$kd_table" ]]; then
                if [[ -n "${descriptions[$commands_ARGS]}" ]]; then
                    if [[ "$commands_ARGS" == "nano" ]]; then
                        if ! command -v nano &> /dev/null; then
                            help_dialog_kd "invalid"
                        else
                            echo "${descriptions[$commands_ARGS]}"
                        fi
                    elif [[ "$commands_ARGS" == "compile" ]]; then
                        echo "${descriptions[$commands_ARGS]}"
                        echo " Example: compile bare.pwn +option_amx"
                        echo " For Option. Please See: github.com/vilksons/kodo/wiki/Compiler-Option"
                    else
                        echo "${descriptions[$commands_ARGS]}"
                    fi
                else
                    help_dialog_kd "invalid"
                fi
            else
                help_dialog_kd ""
            fi

            typeof ""
            ;;
        "$trigger_kd" | "user:~$:" | " ")
            echo "Hello there!"
            typeof ""
            ;;
        "")
            typeof ""
            ;;
        *)
            not_found_kd ""

            __commands__=(
                help
                compile
                running
                irunn
                debug
                stop
                restart
                gamemode
                pawncc
                clear
                checksums
                cat
                kill
                sync
                modular
                directory
                exit
                remcac
                vireon
                toml
                fetch
                nano
                zapman
            )

            for val in "${__commands__[@]}"; do
                if [[ "$kd_table" == "$val" ]]; then
                    echo "did you mean '$val'?"
                elif [[ "$kd_table" == *"$val"* ]] || [[ "$val" == *"$kd_table"* ]]; then
                    echo "did you mean '$val'?"
                fi
            done

            struct_kodo_t_main ""
            ;;
    esac
}
export goto_mode_KODO

function not_found_kd()
{
    echo "error: $kd_table: command not found..."
}

function help_dialog_kd()
{
    local _param_=$1

    if [[ "$_param_" == "invalid" ]]; then
        echo "Invalid!.. Please Use:"
    fi

    echo "Usage: kodo <flags> | help | -h | --h | [<commands>] [<args>]"
    echo "Help Usage: help <commands> | help compile | help running"
    echo "Tip: use CTRL+C to exit and use CTRL+D to back"
    echo "Commands:"
    echo " | Kodo |"
    echo " compile (compile project)"
    echo " running (running project)"
    echo " irunn (compile-run project)"
    echo " debug (debugging project)"
    echo " stop (stopped project)"
    echo " restart (restart project)"
    echo " gamemode (download gamemode)"
    echo " pawncc (download pawncc)"
    echo " clear (clear-screen)"
    echo " checksums (checksums of workspace)"
    echo " cat (cat file to terminal)"
    echo " kill (kill/restart terminal)"
    echo " sync (update/upgrade)"
    echo " modular (module checking)"
    echo " directory (change/display current directory)"
    echo " exit (exit from terminal)"
    echo " remcac (remove cache ~/.cache/)"
    echo " vireon (Vireon, A.I Chat)"
    echo " toml (rebuild kodo.toml)"
    echo " refresh (refresh terminal, kodo.toml, etc.)"
    echo " fetch (fetch of workspace)"
    
    if command -v nano &> /dev/null; then
        echo " nano (run nano editor from terminal)"
    fi

    echo " | Zapman |"
    echo " zapman (enter Zapman)"
    echo " autoinstall (install packages from cache)"
    echo " install (install packages)"
    echo " remove (remove packages)"
    echo " exit (exit Zapman)"
}

function help_dialog_zapman()
{
    echo "Usage: zapman | <command> [<args>]"
    echo "Commands:"
    echo " autoinstall - Auto-Install from Zapman cache"
    echo " install     - Install/Reinstall Packages"
    echo " remove      - Remove Packages"
    echo " exit        - Exit Zapman Mode"
}

function end_kodo_t_main() {
    echo -e "$(collor_yellow "# Press any key..")"
    read -r -n 1 -s
    struct_kodo_t_main ""
}

: '
    @summary: Main
'
struct_kodo_t_main ""
