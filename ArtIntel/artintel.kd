#!/bin/bash

function kodo_artintel()
{
    local commands_INPUT=$1

    chatbot_response=$(curl -s -X POST https://api.groq.com/openai/v1/chat/completions \
        -H "Authorization: Bearer $DECRYPT_TOKEN" \
        -H "Content-Type: application/json" \
        -d "{
            \"model\": \"$json_CHATBOT_MODEL\",
            \"messages\": [
                {
                \"role\": \"system\",
                \"content\": \"$json_CHATBOT_BIODATA\"
                },
                {
                \"role\": \"user\",
                \"content\": \"$commands_INPUT\"
                }
            ],
            \"temperature\": 1,
            \"max_tokens\": 1024,
            \"top_p\": 1,
            \"stream\": false,
            \"stop\": null
        }")
         
    echo "$chatbot_response" | python3 -c "
import sys, json, re, time

# define ANSI color codes #
GREEN = '\033[32m'
RED = '\033[31m'
ORANGE = '\033[33m'
GRAY = '\033[37m'
RESET = '\033[0m'

# define color groups #
color_groups = {
    GREEN: [
        'true', 'string', 'int', 'float', 'bool',
        'double', 'char', 'if', 'else', 'while', 'for', 'do',
        'switch', 'case', 'class', 'void', 'inline', 'include', 'end', 'printf', 'print', 'std'
    ],
    RED: ['false', 'return', 'throw', 'break', 'continue', 'foo', 'sudo'],
    ORANGE: ['try', 'catch', 'finally', 'goto', 'main'],
    GRAY: ['gcc', 'clang', 'sudo'],
}

# flatten into a single keyword-to-color dictionary #
COLORS = {kw: color for color, keywords in color_groups.items() for kw in keywords}

def highlight(match):
    word = match.group(0)
    color = COLORS.get(word.lower())
    return f'{color}{word}{RESET}' if color else word

def process_text(text):
    # split text into code blocks and non-code blocks #
    parts = re.split(r'(\`\`\`.*?\n.*?\`\`\`|\`.*?\`)', text, flags=re.DOTALL)
    
    result = []
    for i, part in enumerate(parts):
        if i % 2 == 1:
            if part.startswith('\`\`\`'):
                code_content = part[3:-3]
                pattern = r'\\b(' + '|'.join(re.escape(k) for k in COLORS.keys()) + r')\\b'
                highlighted_code = re.sub(pattern, highlight, code_content, flags=re.IGNORECASE)
                result.append(f'\`\`\`{highlighted_code}\`\`\`')
            else:
                code_content = part[1:-1]
                pattern = r'\\b(' + '|'.join(re.escape(k) for k in COLORS.keys()) + r')\\b'
                highlighted_code = re.sub(pattern, highlight, code_content, flags=re.IGNORECASE)
                result.append(f'\`{highlighted_code}\`')
        else:
            result.append(part)
    
    return ''.join(result)

try:
    data = json.load(sys.stdin)
    chatbot_response = data.get('choices', [{}])[0].get('message', {}).get('content')

    if not chatbot_response:
        raise ValueError('Error: Response API Failed/not found.')

    processed_response = process_text(chatbot_response)

    for char in processed_response:
        print(char, end='', flush=True)
        time.sleep(0.03)
    print()

except json.JSONDecodeError:
    print('Error: Invalid JSON', flush=True)
except ValueError as e:
    print(e, flush=True)
except KeyboardInterrupt:
    print(' Cancelled', end='', flush=True)
    sys.exit(130)
"

    end_console_main ""
    echo
}